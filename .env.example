# Демо-значения для локального Docker Compose — не секреты.
# Реальный .env в репозиторий не коммитится (.gitignore).

POSTGRES_USER=sidequest
POSTGRES_PASSWORD=sidequest
POSTGRES_DB=sidequest

# Для запуска бэкенда вне Docker (контейнерный Postgres проброшен на 5433)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
REDIS_URL=redis://localhost:6379/0
